# Copy this file to ".env" (same folder) and paste your real key below.
# Get a free key at https://aistudio.google.com/apikey

GEMINI_API_KEY=paste_your_real_key_here
PORT=3001

# --- Added for user accounts, database, and REST API ---
# Get a free MongoDB Atlas connection string at https://www.mongodb.com/cloud/atlas
MONGODB_URI=paste_your_mongodb_connection_string_here
# Any long random string works for JWT_SECRET — used to sign login tokens
JWT_SECRET=change_this_to_any_long_random_string
